# ---- generated outputs (never committed; regenerate with `stride-s0`) -------
outputs/*
!outputs/.gitkeep
outputs_s1a/
outputs_s1b/
outputs_s2/
outputs_s3/
outputs_s4/
outputs_s5/
outputs_s6/
*.parquet
*.log

# ---- user-supplied datasets (Level 0/1/2 real data are NOT source) ----------
# The example under examples/ IS committed; real datasets under data/ are not.
data/*
!data/README.md

